{
  "name": "trip-ticket-pipeline",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "studio": "node pipeline/server.mjs",
    "mcp": "node pipeline/mcp-server.mjs",
    "plan": "node pipeline/orchestrator.mjs",
    "plan:mock": "node pipeline/orchestrator.mjs --mock",
    "demo": "node scripts/generate-itinerary-preview.mjs",
    "composio:smoke": "node scripts/composio-smoke.mjs",
    "deploy": "wrangler deploy --config wrangler.itinerary.toml",
    "test": "TRIP_NO_LLM=1 node --test 'tests/**/*.test.mjs'"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.0",
    "@composio/core": "^0.13.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260715.1",
    "typescript": "^5.5.0",
    "wrangler": "^4.111.0"
  },
  "allowScripts": {
    "esbuild@0.17.19": true,
    "workerd@1.20250718.0": true
  }
}
